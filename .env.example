# Rename this to .env and fill in your values
# (Never commit the real .env to git)

API_ID=12345678
API_HASH=your_api_hash_here
BOT_TOKEN=123456789:ABC-your_bot_token_here

# Optional: channel ID for storing large files (your BIN_CHANNEL pattern)
BIN_CHANNEL=0

# Working directory for temp files
WORK_DIR=/tmp/zilong_work

# Optional: path to yt-dlp cookies.txt for restricted content
COOKIES_FILE=
